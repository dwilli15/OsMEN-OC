#!/usr/bin/env bash
# pre-commit hook: block commits that contain secret patterns.
# Install: cp scripts/hooks/pre-commit-secrets .git/hooks/pre-commit
#          chmod +x .git/hooks/pre-commit
#
# Scans staged files for high-entropy tokens, API keys, and known secret
# patterns. Excludes template files and encrypted files by design.

set -euo pipefail

# Patterns that indicate a real secret (not a template placeholder).
# Each pattern is a PCRE matched case-insensitively against staged diffs.
SECRET_PATTERNS=(
    'ghp_[A-Za-z0-9]{36}'                    # GitHub PAT (classic)
    'ghu_[A-Za-z0-9]{36}'                     # GitHub user token
    'ghs_[A-Za-z0-9]{36}'                     # GitHub app token
    'sk-[A-Za-z0-9]{20,}'                     # OpenAI-style API key
    'xoxb-[0-9]{10,}-[A-Za-z0-9]+'            # Slack bot token
    'AIza[A-Za-z0-9_-]{35}'                   # Google API key
    'age1[a-z0-9]{58}'                        # age public key (recipient)
    'AGE-SECRET-KEY-[A-Z0-9]+'                # age private key
    'AKIA[A-Z0-9]{16}'                        # AWS access key
    '[0-9]{8,}:AA[A-Za-z0-9_-]{33}'           # Telegram bot token
    'MTQ[0-9A-Za-z]{20,}\.[A-Za-z0-9_-]+'     # Discord bot token
)

# Files to always exclude from scanning.
EXCLUDE_GLOBS=(
    '*.template.yaml'
    '*.enc.yaml'
    'scripts/hooks/pre-commit-secrets'
    'tests/*'
    '*.md'
)

build_exclude_args() {
    local args=()
    for glob in "${EXCLUDE_GLOBS[@]}"; do
        args+=(":(exclude)${glob}")
    done
    printf '%s\n' "${args[@]}"
}

main() {
    local found=0
    local diff_output
    diff_output=$(git diff --cached --diff-filter=ACMR -U0 -- . $(build_exclude_args) 2>/dev/null || true)

    if [[ -z "${diff_output}" ]]; then
        exit 0
    fi

    for pattern in "${SECRET_PATTERNS[@]}"; do
        local matches
        matches=$(echo "${diff_output}" | grep -P "${pattern}" 2>/dev/null || true)
        if [[ -n "${matches}" ]]; then
            echo "ERROR: Potential secret detected in staged changes!"
            echo "Pattern: ${pattern}"
            echo "${matches}" | head -5
            echo ""
            found=1
        fi
    done

    if [[ "${found}" -eq 1 ]]; then
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "BLOCKED: Secrets detected in staged files."
        echo "If this is a false positive, use: git commit --no-verify"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        exit 1
    fi
}

main "$@"
