# OsMEN-OC Caddyfile — reverse proxy for *.osmen.local services.
# TLS disabled (local-only, no public exposure).
# All backends are localhost containers on published ports.

{
	# Disable HTTPS for local DNS (no certs needed).
	auto_https off
}

