HealthInterval=30s
HealthTimeout=10s
HealthRetries=5
HealthStartPeriod=30s

ReadOnly=true
SecurityLabelDisable=true
NoNewPrivileges=true

[Service]
Restart=always
RestartSec=5s
Slice=user-osmen-core.slice
MemoryMax=1G
CPUQuota=200%

[Install]
WantedBy=default.target
