[Container]
ContainerName=osmen-media-komga-comics
Image=docker.io/gotson/komga:1.24.3
Volume=/home/dwill/media/comics:/comics:ro
Volume=/home/dwill/media/komga-config-comics:/config
PublishPort=127.0.0.1:25600:25600
Network=osmen-media.network
Label=io.containers.autoupdate=registry

[Service]
Restart=always
